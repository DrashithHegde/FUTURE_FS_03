# Copy this file to .env and fill in real values. Do NOT commit .env to git.
# Example root-level environment variables used by docker-compose and local scripts.

POSTGRES_PASSWORD=your_db_password_here
PGADMIN_DEFAULT_EMAIL=admin@crm.com
PGADMIN_DEFAULT_PASSWORD=your_pgadmin_password_here

# Optional: any other root-level vars referenced by docker-compose
# e.g. PGDATA=/var/lib/postgresql/data
